# Riot Games API credentials for the League scripts.
# Copy this file to ".env" and fill in real values. The .env file is gitignored.
#
# Get a key at https://developer.riotgames.com (personal keys are persistent
# but rate-limited; rotate it if it ever leaks).

RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
RIOT_GAME_NAME=NoAnimeNoLife
RIOT_TAG_LINE=ANIME
